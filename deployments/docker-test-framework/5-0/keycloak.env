
# change these values to point to a running postgres instance
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres:5432/KEYCLOAK
KC_DB_USERNAME=irods
KC_DB_PASSWORD=testpassword
KC_HOSTNAME=localhost

# Admin user bootstrap
KEYCLOAK_ADMIN=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Google OIDC identity provider settings used by realm-drs.json import
# Create an OAuth client in Google Cloud and copy credentials here.
# These must be real Google OAuth web client credentials (not placeholders).
GOOGLE_OIDC_CLIENT_ID=${GOOGLE_OIDC_CLIENT_ID}
GOOGLE_OIDC_CLIENT_SECRET=${GOOGLE_OIDC_CLIENT_SECRET}
# DRS API client imported as bearer-only resource server in realm-drs.json
DRS_API_CLIENT_ID=${DRS_API_CLIENT_ID}
DRS_API_CLIENT_SECRET=${DRS_API_CLIENT_SECRET}
# Browser-login client for irods-go-rest. This must not be bearer-only.
IRODS_REST_WEB_CLIENT_ID=${IRODS_REST_WEB_CLIENT_ID}
IRODS_REST_WEB_CLIENT_SECRET=${IRODS_REST_WEB_CLIENT_SECRET}
# In Google Cloud Console, add this as an Authorized redirect URI:
# https://localhost:8443/realms/drs/broker/google/endpoint
